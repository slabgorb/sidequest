#!/usr/bin/env bash
set -euo pipefail

SCRIPT_NAME="$(basename "$0")"

usage() {
  cat <<EOF
$SCRIPT_NAME — Generate starting equipment for a character from genre pack data.

Call at character creation when introducing the character's starting gear.

Usage:
  $SCRIPT_NAME --class CLASS [OPTIONS]

Options:
  --class NAME        Character class or archetype name (REQUIRED).
  --tier N            Power tier 1-4 for scaling the loadout (default: 1).
  -h, --help          Show this help.

Environment (set by the engine — do not set manually):
  SIDEQUEST_GENRE           Genre slug for the current session (e.g., low_fantasy)
  SIDEQUEST_CONTENT_PATH    Path to sidequest-content repo (default: ~/Projects/sidequest-content)
  SIDEQUEST_API_BIN         Path to API binary directory (default: ~/Projects/sidequest-api/target/debug)

Output:
  JSON with: class, currency_name, starting_gold, equipment[],
  narrative_hook, total_value

Example:
  $SCRIPT_NAME --class rogue
  $SCRIPT_NAME --class fighter --tier 2
EOF
  exit 0
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && usage

# Resolve paths from environment with defaults
CONTENT_PATH="${SIDEQUEST_CONTENT_PATH:-$HOME/Projects/sidequest-content}"
API_BIN="${SIDEQUEST_API_BIN:-$HOME/Projects/sidequest-api/target/debug}"
GENRE="${SIDEQUEST_GENRE:-}"

if [[ -z "$GENRE" ]]; then
  echo "ERROR: SIDEQUEST_GENRE is not set. The engine must set this per-session." >&2
  exit 1
fi

BINARY="$API_BIN/sidequest-loadoutgen"
if [[ ! -x "$BINARY" ]]; then
  echo "ERROR: Binary not found at $BINARY — run 'cargo build' in sidequest-api." >&2
  exit 1
fi

exec "$BINARY" \
  --genre-packs-path "$CONTENT_PATH/genre_packs" \
  --genre "$GENRE" \
  "$@"
